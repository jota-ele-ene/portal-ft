<%-
  include('layout', {
    title: title,
    body: `
  <div style="max-width:920px;margin:0 auto">
    <div style="display:flex;justify-content:flex-start;align-items:center;margin:.5rem">
      <div>
        <h1 style="font-size:1.2rem;font-weight:700;color:var(--text)">Editar perfil de proveedor</h1>
        <p style="color:var(--text-muted);font-size:.9rem;margin-top:.25rem">Completa la información en cada pestaña y guarda el borrador o envía para revisión.</p>
      </div>
    </div>

    <div class="tabs" style="gap:.25rem;margin-bottom:.5rem;     padding-left: 1em;">
      <button type="button" class="tab active" data-tab="tab-fiscal">Fiscal</button>
      <button type="button" class="tab" data-tab="tab-contacto">Contacto</button>
      <button type="button" class="tab" data-tab="tab-bancario">Bancario</button>
      <button type="button" class="tab" data-tab="tab-docs">Documentos</button>
    </div>

    <form id="supplierForm" novalidate>
      <div id="tab-fiscal" class="tab-panel active">
        <div class="card" style="padding:1rem">
          <div class="form-grid">
            <div class="form-group">
              <label class="form-label" for="razon_social">Razón social <span style="color:var(--error)">*</span></label>
              <input class="form-control" type="text" id="razon_social" name="razon_social" required>
            </div>
            <div class="form-group">
              <label class="form-label" for="nombre_comercial">Nombre comercial</label>
              <input class="form-control" type="text" id="nombre_comercial" name="nombre_comercial">
            </div>
            <div class="form-group">
              <label class="form-label" for="nif">NIF / CIF <span style="color:var(--error)">*</span></label>
              <input class="form-control" type="text" id="nif" name="nif" placeholder="B12345678" required>
            </div>
            <div class="form-group">
              <label class="form-label" for="actividad">Actividad económica</label>
              <input class="form-control" type="text" id="actividad" name="actividad">
            </div>
            <div class="form-group" style="grid-column:1/-1">
              <label class="form-label" for="direccion">Dirección fiscal <span style="color:var(--error)">*</span></label>
              <input class="form-control" type="text" id="direccion" name="direccion" required>
            </div>
            <div class="form-group">
              <label class="form-label" for="codigo_postal">Código postal</label>
              <input class="form-control" type="text" id="codigo_postal" name="codigo_postal" placeholder="28001">
            </div>
            <div class="form-group">
              <label class="form-label" for="ciudad">Ciudad</label>
              <input class="form-control" type="text" id="ciudad" name="ciudad">
            </div>
          </div>
        </div>
      </div>

      <div id="tab-contacto" class="tab-panel">
        <div class="card" style="padding:1rem">
          <div class="form-grid">
            <div class="form-group">
              <label class="form-label" for="persona_contacto">Persona de contacto <span style="color:var(--error)">*</span></label>
              <input class="form-control" type="text" id="persona_contacto" name="persona_contacto" required>
            </div>
            <div class="form-group">
              <label class="form-label" for="email_contacto">Email de contacto <span style="color:var(--error)">*</span></label>
              <input class="form-control" type="email" id="email_contacto" name="email_contacto" required>
            </div>
            <div class="form-group">
              <label class="form-label" for="telefono">Teléfono</label>
              <input class="form-control" type="tel" id="telefono" name="telefono" placeholder="+34 600 000 000">
            </div>
          </div>
        </div>
      </div>

      <div id="tab-bancario" class="tab-panel">
        <div class="card" style="padding:1rem">
          <div class="form-grid">
            <div class="form-group">
              <label class="form-label" for="iban">IBAN <span style="color:var(--error)">*</span></label>
              <input class="form-control" type="text" id="iban" name="iban" placeholder="ES00 0000 0000 0000 0000 0000" required>
            </div>
            <div class="form-group">
              <label class="form-label" for="banco">Entidad bancaria</label>
              <input class="form-control" type="text" id="banco" name="banco">
            </div>
          </div>
        </div>
      </div>

      <div id="tab-docs" class="tab-panel">
        <div class="card" style="padding:1rem">
          <p style="font-size:.85rem;color:var(--text-muted);margin-bottom:1rem">Sube documentos con su tipo. El nombre personalizado se verá en la lista de archivos.</p>
          <button type="button" class="btn btn-secondary" onclick="openUploadModal()">Subir documento</button>

          <div id="uploadedDocs" style="margin-top:1rem"></div>
        </div>
      </div>

      <div style="display:flex;gap:.75rem;justify-content:flex-end;margin-top:1rem">
        <button type="button" class="btn btn-secondary" onclick="window.location.href='/perfil'">Cancelar</button>
        <button type="button" class="btn btn-secondary" onclick="saveDraft()">Guardar borrador</button>
        <button type="submit" class="btn btn-primary" id="submitFormBtn">Enviar para revisión</button>
      </div>

      <div id="uploadModal" class="modal" inert>
        <div class="modal-backdrop" onclick="closeUploadModal()"></div>
        <div class="modal-panel">
          <h2>Subir documento</h2>
          <p style="color:var(--text-muted);margin:.5rem 0 1rem 0">Elige el tipo de documento y un nombre visible.</p>
          <div class="form-group">
            <label class="form-label" for="documentType">Tipo de documento</label>
            <select class="form-control" id="documentType">
              <option value="">Seleccionar tipo</option>
              <option>Certificado</option>
              <option>Contrato</option>
              <option>Factura</option>
              <option>Documento de identidad</option>
              <option>Otro</option>
            </select>
          </div>
          <div class="form-group" id="customLabelGroup" style="display:none;">
            <label class="form-label" for="documentLabel">Nombre visible</label>
            <input class="form-control" type="text" id="documentLabel" placeholder="Escribe un nombre corto">
          </div>
          <div class="form-group">
            <label class="form-label" for="documentFile">Fichero</label>
            <input class="form-control" type="file" id="documentFile" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx">
          </div>
          <div style="display:flex;justify-content:flex-end;gap:.75rem;margin-top:1rem">
            <button type="button" class="btn btn-secondary" onclick="closeUploadModal()">Cerrar</button>
            <button type="button" class="btn btn-primary" onclick="submitDocumentUpload()">Subir</button>
          </div>
        </div>
      </div>
    </form>
  </div>
    `,
    scripts: ['/static/js/supplier-form.js']
  })
%>
