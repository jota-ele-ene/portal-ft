<%-
  include('layout', {
    title: 'Gestión de proveedores',
    body: `
  <section id="admin-dashboard">
    <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:1.5rem;flex-wrap:wrap;gap:1rem">
      <div>
        <h1 style="font-size:1.3rem;font-weight:700">Proveedores registrados</h1>
        <p style="color:var(--text-muted);font-size:.88rem;margin-top:.25rem" id="supplierCount">Cargando…</p>
      </div>
      <div style="display:flex;gap:.5rem;flex-wrap:wrap;align-items:center">
        <input class="form-control" type="search" id="searchInput" placeholder="Buscar…" style="width:200px" oninput="filterTable()">
        <select class="form-control" id="statusFilter" style="width:150px" onchange="filterTable()">
          <option value="">Todos los estados</option>
          <option value="pendiente">Pendiente</option>
          <option value="revision">En revisión</option>
          <option value="aprobado">Aprobado</option>
          <option value="rechazado">Rechazado</option>
        </select>
        <button class="btn btn-secondary btn-sm" onclick="loadSuppliers()">⟳ Actualizar</button>
      </div>
    </div>
    <div class="table-wrapper">
      <table class="data-table">
        <thead>
          <tr>
            <th>Razón social</th>
            <th>NIF</th>
            <th>Email</th>
            <th>Estado</th>
            <th>Actualizado</th>
            <th>Cambiar estado</th>
          </tr>
        </thead>
        <tbody id="suppliersBody">
          <tr><td colspan="6" style="text-align:center;padding:2.5rem;color:var(--text-faint)">Cargando…</td></tr>
        </tbody>
      </table>
    </div>
  </section>`,
    scripts: ['/static/js/admin.js']
  })
%>
