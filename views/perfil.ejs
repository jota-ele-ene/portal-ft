<%
  const modeValue = typeof mode !== 'undefined' ? mode : 'view';
  const isEdit = modeValue === 'edit';
  const scriptSrc = isEdit ? '/static/js/supplier-form.js' : '/static/js/supplier-view.js';
%>
<%- include('layout', {
  title: title,
  includeMain: function() {
    return include('partials/perfil-common', { mode: modeValue, supplierId: supplierId });
  },
  scripts: [
    'https://cdnjs.cloudflare.com/ajax/libs/validator/13.9.0/validator.min.js',
    scriptSrc
  ]
}) %>
