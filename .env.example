# ── Portal de Proveedores — Variables de entorno ──────────────────────────────
# Copia como .env y ajusta los valores

# Parámetros del servidor. Se usan en los correos y notificaciones
PORT=8888
PORTAL_URL=https://portal.tuempresa.com
ADMIN_EMAIL=info@tuempresa.com

# Destinatario del correo con los datos actualizados donde enviar las actualizaciones para incorporarlas en los maestros
GEST_EMAIL=gestion@tuempresa.com

# Secreto JWT (mínimo 32 caracteres, cámbialo siempre en producción)
JWT_SECRET=genera-una-clave-aleatoria-segura-aqui-32chars

# Expiración del token de sesión (minutos)
TOKEN_EXPIRE_MINUTES=120

# Tiempo de vida del código OTP (segundos)
OTP_TTL_SECONDS=300

# ── SMTP ─────────────────────────────────────────────────────────────────────
# Deja SMTP_USER vacío para modo desarrollo (OTP aparece en logs del contenedor auth)
SMTP_HOST=smtp.tuempresa.com
SMTP_PORT=587
SMTP_USER=portal@tuempresa.com
SMTP_PASS=tu-contraseña-smtp
SMTP_FROM=no-reply@tuempresa.com

# ── Archivos ─────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
